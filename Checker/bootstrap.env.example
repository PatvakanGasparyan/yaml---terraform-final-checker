# Bootstrap configuration for EC2 — S3 location only (no secrets).
# Copy to bootstrap.env on the EC2 instance and set your bucket/key.

ENV_S3_BUCKET=your-config-bucket-name
ENV_S3_KEY=checker/.env
ENV_FILE_PATH=.env
AWS_DEFAULT_REGION=us-east-1

# EC2 instance IAM role should grant s3:GetObject on the bucket/key above.
# Do NOT put application secrets in this file.
