# Environment variables for YAML & Terraform AI Validator
# Copy to .env and customize for production

# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database
MYSQL_HOST=5555
MYSQL_PORT=3306
MYSQL_USER=validator
MYSQL_PASSWORD=validator_secret
MYSQL_DATABASE=yaml_terraform_validator

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AI / LLM (optional — enables full LLM analysis)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=8192
AI_TOP_P=0.95
# Override the default system prompt (leave empty for built-in DevOps prompt)
AI_SYSTEM_PROMPT=

# Azure OpenAI (alternative)
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Ollama / local LLM (alternative)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.3

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=github-webhook-secret-change-me

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317
