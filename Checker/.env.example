# Environment variables for YAML & Terraform AI Validator
# Copy to .env and customize for production / EC2 deployment

# Application
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database — use sqlite for EC2 minimal (docker-compose.ec2.yml)
# Use mysql for full stack (docker-compose.yml)
DB_ENGINE=sqlite
SQLITE_PATH=/app/data/app.db

# MySQL (only when DB_ENGINE=mysql)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=validator
MYSQL_PASSWORD=validator_secret
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=yaml_terraform_validator

# Redis (only when using docker-compose.yml with worker profile)
REDIS_HOST=disabled

# AI / LLM (optional — enables full LLM analysis)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=8192
AI_TOP_P=0.95
# Override the default system prompt (leave empty for built-in DevOps prompt)
AI_SYSTEM_PROMPT=

# Azure OpenAI (alternative)
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Ollama / local LLM (alternative)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.3

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://0.0.0.0:8000/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=github-webhook-secret-change-me

# Public API (replace 0.0.0.0 with your EC2 public IP)
PUBLIC_HOST=0.0.0.0
FRONTEND_URL=http://0.0.0.0:8000

# CORS
CORS_ORIGINS=http://0.0.0.0,http://0.0.0.0:80,http://0.0.0.0:8000

# OpenTelemetry (optional — disabled by default)
OTEL_ENABLED=false
